{
  "name": "@honknet-solutions/honknet-client",
  "version": "0.2.0-rc.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "predev": "npm --prefix ../.. run copy:resources",
    "prebuild": "npm --prefix ../.. run copy:resources",
    "test": "vitest run --pool=forks --maxWorkers=1 --minWorkers=1 --no-file-parallelism"
  },
  "dependencies": {
    "pixi.js": "^8.19.0",
    "@honknet/hui-runtime": "file:../../packages/hui-runtime",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.7"
  }
}
